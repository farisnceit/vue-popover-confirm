{
  "name": "vue-popover-confirm",
  "version": "1.0.0",
  "description": "A Vue 3 plugin for confirmation popovers",
  "type": "module",
  "main": "./dist/vue-popover-confirm.cjs.js",
  "module": "./dist/vue-popover-confirm.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue-popover-confirm.es.js",
      "require": "./dist/vue-popover-confirm.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css",
    "./composables": {
      "import": "./dist/composables.js",
      "require": "./dist/composables.cjs.js",
      "types": "./dist/composables.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "dist/style.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --project tsconfig.app.json && vite build",
    "build:lib": "vue-tsc --project tsconfig.lib.json && vite build --mode lib",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "vue",
    "vue3",
    "popover",
    "confirm",
    "dialog",
    "plugin",
    "confirmation",
    "modal",
    "tooltip",
    "floating-ui",
    "composable",
    "typescript",
    "accessible",
    "animation",
    "theme"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.6.1"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.3",
    "@vue/test-utils": "^2.4.6",
    "@vitest/coverage-v8": "^1.6.0",
    "@vitest/ui": "^1.6.0",
    "jsdom": "^24.1.0",
    "typescript": "^5.5.3",
    "vite": "^5.4.2",
    "vitest": "^1.6.0",
    "vue": "^3.4.38",
    "vue-tsc": "^2.1.4"
  }
}