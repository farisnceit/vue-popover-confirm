{
  "name": "vue-popover-confirm",
  "version": "1.0.0",
  "description": "A Vue 3 plugin for confirmation popovers",
  "type": "module",
  "main": "./dist/vue-popover-confirm.cjs.js",
  "module": "./dist/vue-popover-confirm.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/vue-popover-confirm.es.js",
      "require": "./dist/vue-popover-confirm.cjs.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "dist/style.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc && vite build",
    "build:lib": "vite build --mode lib && vue-tsc --project tsconfig.lib.json",
    "preview": "vite preview"
  },
  "keywords": [
    "vue",
    "vue3",
    "popover",
    "confirm",
    "dialog",
    "plugin"
  ],
  "author": "",
  "license": "MIT",
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "dependencies": {
    "@floating-ui/dom": "^1.6.1",
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.1.3",
    "typescript": "^5.5.3",
    "vite": "^5.4.2",
    "vue-tsc": "^2.1.4"
  }
}
